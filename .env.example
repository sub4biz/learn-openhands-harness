# Copy this to .env or export these variables in your shell.
# Never commit a real API key or paste one into prompts, issues, docs, or chat.

# Required for SDK scripts and live agent runs.
LLM_API_KEY=

# Optional. Defaults in the scripts already use Sonnet 4.5.
LLM_MODEL=anthropic/claude-sonnet-4-5-20250929

# Optional for routing experiments.
LLM_MODEL_SMALL=anthropic/claude-haiku-4-5-20251001

# Optional for the capstone router. Empty means "fall back to LLM_MODEL".
LLM_MODEL_FLAGSHIP=

# Optional. Point this at the repo the agent should inspect.
WORKSPACE_DIR=/path/to/agent-canvas

# Optional for Dockerized Agent Canvas servers. If Agent Canvas mounts your
# projects directory at /projects, these let the tutorial scripts map host paths
# such as /Users/you/Code/agent-canvas to /projects/agent-canvas.
AGENT_WORKSPACE_HOST_ROOT=
AGENT_WORKSPACE_SERVER_ROOT=/projects
